PORT=3000
MYSQL_HOST=your_mysql_host
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=your_mysql_database

# ── Supabase (Lab Result PDF Storage) ────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_LAB_BUCKET=lab-results
SUPABASE_USE_SIGNED_URL=true
SUPABASE_SIGNED_URL_TTL=3600

# ── Chart Tracking ───────────────────────────────────────────
# Earliest discharge date to include in chart tracking (YYYY-MM-DD)
VITE_SUPABASE_TRACKING_DISCHARGE_START_DATE=2026-01-01
